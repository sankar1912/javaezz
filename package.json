{
  "name": "javaezz",
  "displayName": "javaezz",
  "description": "Java productivity shortcuts",
  "version": "0.0.2",
  "publisher": "SankaraNarayananK",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
  "java",
  "snippets",
  "productivity",
  "intellisense",
  "boilerplate"
],
  "repository": {
    "type": "git",
    "url": "https://github.com/sankar1912/javaezz"
  },
  "activationEvents": [
  "onLanguage:java"
],
  "main": "./extension.js",
  "contributes": {
    "commands": [{
      "command": "javaezz.helloWorld",
      "title": "Hello World"
    }]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
